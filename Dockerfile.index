# 基于Python 3.11的基础镜像
FROM python:3.11-slim

# 设置工作目录
WORKDIR /app/index

# 复制依赖文件
COPY index/requirements.txt .

# 安装依赖
RUN pip install --no-cache-dir -r requirements.txt

# 复制应用代码
COPY index/ .

# 复制启动脚本
COPY index/start.sh .

# 给启动脚本添加执行权限
RUN chmod +x start.sh

# 暴露端口
EXPOSE 5000

# 启动应用
CMD ["./start.sh"]