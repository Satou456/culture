# 基于 Node.js 20 镜像
FROM node:20-alpine

# 设置工作目录
WORKDIR /app/frontend

# 复制依赖文件
COPY chinese-national-culture-museum/frontend/package*.json ./

# 安装依赖
RUN npm install

# 复制前端代码
COPY chinese-national-culture-museum/frontend/ .

# 构建前端项目
RUN npm run build

# 暴露端口
EXPOSE 5173

# 启动开发服务器
CMD ["npm", "run", "dev"]
