# 前端构建阶段
FROM node:20-alpine AS frontend-build

# 设置工作目录
WORKDIR /app/frontend

# 复制依赖文件
COPY chinese-national-culture-museum/frontend/package*.json ./

# 安装依赖
RUN npm install

# 复制前端代码
COPY chinese-national-culture-museum/frontend/ .

# 构建前端
RUN npm run build

# 后端构建阶段
FROM maven:3.9-eclipse-temurin-17 AS backend-build

# 设置工作目录
WORKDIR /app/backend

# 复制后端代码
COPY chinese-national-culture-museum/backend/ .

# 构建后端
RUN mvn clean package

# 最终镜像
FROM eclipse-temurin:17-jre-alpine

# 设置工作目录
WORKDIR /app

# 复制后端构建结果
COPY --from=backend-build /app/backend/community-service/target/community-service.jar .

# 复制前端构建结果
COPY --from=frontend-build /app/frontend/dist/ ./static/

# 暴露端口
EXPOSE 8080

# 启动应用
CMD ["java", "-jar", "community-service.jar"]