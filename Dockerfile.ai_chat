# 基于Python 3.11的基础镜像
FROM python:3.11-slim

# 设置工作目录
WORKDIR /app/ai_chat

# 复制依赖文件
COPY ai_chat/pyproject.toml .

# 安装依赖
RUN pip install --no-cache-dir uv
RUN uv sync

# 复制应用代码
COPY ai_chat/ .

# 暴露端口
EXPOSE 8000

# 启动应用
CMD ["uv", "run", "uvicorn", "app.main:app", "--reload", "--host", "0.0.0.0", "--port", "8000"]