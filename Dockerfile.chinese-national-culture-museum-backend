# 后端构建阶段
FROM maven:3.9-eclipse-temurin-17 AS backend-build

# 设置工作目录
WORKDIR /app/backend

# 复制后端代码
COPY chinese-national-culture-museum/backend/ .

# 构建后端（跳过测试）
RUN mvn clean install -DskipTests

# 查找生成的 JAR 文件位置
RUN find /app/backend -name "*.jar" -type f

# 最终镜像
FROM eclipse-temurin:17-jre-alpine

# 设置工作目录
WORKDIR /app

# 复制后端构建结果
COPY --from=backend-build /app/backend/community-service/target/community-service-1.0-SNAPSHOT.jar .

# 暴露端口
EXPOSE 8080

# 启动应用
CMD ["java", "-jar", "community-service-1.0-SNAPSHOT.jar"]